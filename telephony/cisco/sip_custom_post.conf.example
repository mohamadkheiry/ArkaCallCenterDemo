; Cisco 7942G extension 222 compatibility override.
; Use only on a trusted LAN with a DHCP reservation and switch-port/MAC controls.
[222](+)
secret=
deny=0.0.0.0/0.0.0.0
permit=192.168.10.170/255.255.255.255
qualify=no
nat=no
host=dynamic
port=5060
insecure=port,invite

; Cisco 7942G extension 200 compatibility override.
; Keep the ACL limited to this phone's DHCP-reserved address.
[200](+)
secret=
deny=0.0.0.0/0.0.0.0
permit=192.168.10.186/255.255.255.255
qualify=no
nat=no
host=dynamic
port=5060
insecure=port,invite
