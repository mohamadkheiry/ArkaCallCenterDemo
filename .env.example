# ================= Arka Call Center — نمونه متغیرهای محیطی =================
# این فایل را به .env کپی کنید و مقادیر واقعی را بگذارید. .env در گیت نیست.
# مقادیر حساس (کلیدها/رمزها) هرگز نباید کامیت شوند.

# ---------- Database (MySQL) ----------
MYSQL_CONNECTION="Server=localhost;Port=3306;Database=arka_callcenter;User=arka;Password=CHANGE_ME;TreatTinyAsBoolean=true;"

# ---------- JWT ----------
JWT_ISSUER="ArkaCallCenter"
JWT_AUDIENCE="ArkaCallCenter"
JWT_SECRET="CHANGE_ME_min_32_chars_random_secret"
JWT_EXPIRE_MINUTES=1440

# ---------- OpenAI (قابل override از پنل سوپرادمین در DB) ----------
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_API_KEY="CHANGE_ME"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
OPENAI_REALTIME_MODEL="gpt-realtime-2.1"
OPENAI_TRANSCRIPTION_MODEL="gpt-4o-transcribe"
TRANSCRIPTION_LANGUAGE="fa"
OPENAI_TTS_MODEL="gpt-4o-mini-tts"

# ---------- SMS.ir (قابل override از پنل سوپرادمین در DB) ----------
SMSIR_API_KEY="CHANGE_ME"
SMSIR_LINE_NUMBER="CHANGE_ME"

# ---------- Isabel / Asterisk ----------
ASTERISK_HOST="192.168.10.101"
ASTERISK_SSH_USER="root"
ASTERISK_SSH_PASSWORD="CHANGE_ME"
# Asterisk REST Interface (ARI) — برای پل صوتی realtime
ASTERISK_ARI_URL="http://192.168.10.101:8088"
ASTERISK_ARI_USER="arka"
ASTERISK_ARI_PASSWORD="CHANGE_ME"
ASTERISK_ARI_APP="arka-ai"

# ---------- App ----------
ASPNETCORE_ENVIRONMENT="Development"
FRONTEND_ORIGIN="http://localhost:5173"
