# ================= Arka Call Center — متغیرهای استقرار (docker compose) =================
# این فایل را به .env کپی کنید و مقادیر واقعی را بگذارید. compose خودکار .env را می‌خواند.
# .env هرگز در گیت قرار نمی‌گیرد؛ اسرار فقط اینجا (روی همان سرور) می‌مانند.

# ---------- پایه ----------
MYSQL_ROOT_PASSWORD=change_me_strong_password
JWT_SECRET=change_me_a_long_random_secret_at_least_32_chars
SUPERADMIN_PHONE=09015909044       # با این شماره وارد شوید (سوپرادمین)

# ---------- پورت‌های میزبان ----------
API_PORT=8080
WEB_PORT=8081
AUDIOSOCKET_PORT=9092
FRONTEND_ORIGIN=http://SERVER_IP:8081
ASPNETCORE_ENVIRONMENT=Production   # برای فعال‌شدن Swagger/Scalar: Development

# ---------- OpenAI (در اولین اجرا در تنظیمات seed می‌شود؛ بعداً از پنل هم قابل تغییر) ----------
OPENAI_API_KEY=sk-...               # کلید OpenAI
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini       # برای بررسی محتوا (moderation)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_REALTIME_MODEL=gpt-realtime  # مدل پاسخ‌گویی تماس
OPENAI_TTS_MODEL=gpt-4o-mini-tts
DEFAULT_VOICE=alloy

# ---------- SMS.ir (ارسال کد تأیید با قالب) ----------
SMSIR_API_KEY=                      # کلید SMS.ir
SMSIR_VERIFY_TEMPLATE_ID=           # شناسه قالب /send/verify (پارامتر CODE)
SMSIR_LINE_NUMBER=                  # (اختیاری) برای پیامک رویدادها

# ---------- Isabel / Asterisk (SSH: ساخت خودکار داخلی + آپلود پیام پذیرش) ----------
ASTERISK_HOST=192.168.10.101
ASTERISK_SSH_USER=root
ASTERISK_SSH_PASSWORD=              # رمز SSH ایزابل
