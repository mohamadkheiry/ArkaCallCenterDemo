# ============ متغیرهای استقرار (docker compose) ============
# این فایل را به .env کنار docker-compose.yml کپی کنید و مقادیر را تنظیم کنید.
# compose به‌صورت خودکار .env را می‌خواند.

# رمز روت MySQL (داخل کانتینر)
MYSQL_ROOT_PASSWORD=arka_root_pass_change_me

# کلید امضای JWT (حداقل ۳۲ کاراکتر)
JWT_SECRET=change_me_please_use_a_long_random_secret_32chars

# شماره موبایل سوپرادمین (اولین بار seed می‌شود؛ با این شماره وارد شوید)
SUPERADMIN_PHONE=09123456789

# پورت‌های میزبان
API_PORT=8080
WEB_PORT=8081
AUDIOSOCKET_PORT=9092

# origin فرانت (برای CORS) — با آدرس واقعی وب جایگزین کنید
FRONTEND_ORIGIN=http://SERVER_IP:8081

# برای دیدن Swagger هنگام تست، Development بگذارید (در تولید Production)
ASPNETCORE_ENVIRONMENT=Production

# ---- کلیدهای زیر را می‌توانید یا اینجا (به‌عنوان override) یا بهتر است از داخل
#      پنل سوپرادمین تنظیم کنید (توصیه‌شده: پنل سوپرادمین، تا در دیتابیس امن بماند) ----
# OpenAI__ApiKey=
# OpenAI__BaseUrl=https://api.openai.com/v1
